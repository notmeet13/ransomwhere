{
  "version": 2,
  "buildCommand": "npm --prefix ForenSync/frontend ci && npm --prefix ForenSync/frontend run build",
  "outputDirectory": "ForenSync/frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
