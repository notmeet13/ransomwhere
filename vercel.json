{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "ForenSync/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1",
      "check": true
    },
    {
      "src": "/assets/(.*)",
      "dest": "/ForenSync/frontend/dist/assets/$1"
    },
    {
      "src": "/(favicon\\.png|favicon\\.svg|logo\\.png|icons\\.svg)",
      "dest": "/$1",
      "check": true
    },
    {
      "src": "/(favicon\\.png|favicon\\.svg|logo\\.png|icons\\.svg)",
      "dest": "/ForenSync/frontend/dist/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/ForenSync/frontend/dist/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
